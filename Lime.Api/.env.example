# Lime.Api 운영 환경변수 — 실제 값은 .env로 복사 (chmod 600), git에 커밋 X
# docker compose --env-file .env up -d

# ── 도메인 / 쿠키 ─────────────────────────────────
WEB_BASE_URL=https://lime.oouya.xyz
# Web과 API가 공유하는 eTLD+1 (lime.oouya.xyz, api-lime.oouya.xyz 둘 다 .oouya.xyz 산하)
COOKIE_DOMAIN=.oouya.xyz

# ── JWT (32자 이상 랜덤, openssl rand -base64 48) ──
JWT_SIGNING_KEY=

# ── DB (Postgres) ────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=lime_db

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# ── OAuth (각 콘솔에서 발급) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api-lime.oouya.xyz/auth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://api-lime.oouya.xyz/auth/kakao/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://api-lime.oouya.xyz/auth/naver/callback

# ── Spotify ──────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Cloudflare R2 (운영 버킷) ─────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_BUCKET_NAME=lime-prod
S3_PUBLIC_URL=https://avatars.lime.oouya.xyz
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
