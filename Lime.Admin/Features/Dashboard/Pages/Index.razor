@page "/"
@attribute [Authorize]

<PageTitle>Lime Admin</PageTitle>

<div class="dashboard-page">
    <main>
        <p class="eyebrow">Lime Admin</p>
        <h1>메인페이지</h1>
    </main>
</div>

<style>
    :global(body) {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f8;
        color: #17202a;
    }

    .dashboard-page {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
    }

    main {
        text-align: center;
    }

    .eyebrow {
        margin: 0 0 8px;
        color: #1f8a70;
        font-size: 13px;
        font-weight: 750;
    }

    h1 {
        margin: 0;
        font-size: 32px;
        line-height: 1.2;
    }
</style>
